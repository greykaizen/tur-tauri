{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Tur",
  "version": "0.5.0",
  "identifier": "com.kaizen.tur",
  "build": {
    "beforeDevCommand": "bun run web:dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run web:build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Tur",
        "width": 880,
        "height": 650,
        "minWidth": 1040,
        "minHeight": 680,
        "resizable": true,
        "decorations": false,
        "transparent": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "shortDescription": "A sleek, multi-engine download manager",
    "longDescription": "Tur is a modern download manager with a native Rust core, built to be lightweight, fast, and highly customizable with support for external engines like aria2c.",
    "category": "Network",
    "publisher": "Kaizen",
    "copyright": "Copyright © 2026 Kaizen",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
