<?xml version="1.0" encoding="UTF-8"?>
<component type="desktop-application">
  <id>io.github.greykaizen.tur</id>

  <name>Tur</name>
  <summary>A sleek, multi-engine download manager</summary>

  <metadata_license>FSFAP</metadata_license>
  <project_license>GPL-3.0-or-later</project_license>

  <developer id="io.github.greykaizen">
    <name>greykaizen</name>
  </developer>

  <description>
    <p>
      Tur is a modern, native download manager built on a high-performance Rust
      core (tur-rs). It supports multiple download engines including its own
      adaptive range-stealing engine and external engines like aria2c, with
      yt-dlp integration for media downloads.
    </p>
    <p>Features:</p>
    <ul>
      <li>Multi-engine support: native tur-rs, aria2c, yt-dlp</li>
      <li>Persistent download queue with SQLite (UUID v7 IDs)</li>
      <li>Parallel segmented downloading for maximum speed</li>
      <li>Clean, modern UI with per-download instance view</li>
      <li>System tray integration and notifications</li>
      <li>Configurable settings per engine</li>
    </ul>
  </description>

