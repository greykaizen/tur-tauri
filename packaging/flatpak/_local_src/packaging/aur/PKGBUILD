# Maintainer: greykaizen <greykaizen@github.com>
pkgname=tur-bin
pkgver=0.5.0
pkgrel=1
pkgdesc="A sleek, multi-engine download manager with a native Rust core"
arch=('x86_64')
url="https://github.com/greykaizen/tur-tauri"
license=('MIT')
depends=('webkit2gtk-4.1' 'gtk3' 'cairo' 'pango' 'glib2' 'openssl' 'libayatana-appindicator')
provides=('tur')
conflicts=('tur')
source=("${pkgname}-${pkgver}.deb::https://github.com/greykaizen/tur-tauri/releases/download/v${pkgver}/tur_${pkgver}_amd64.deb")
sha256sums=('SKIP') # Update this with: makepkg -g

package() {
    # Extract data from deb
    ar x "${pkgname}-${pkgver}.deb"
    tar xf data.tar.* -C "${pkgdir}"

    # Fix permissions
    chmod -R 755 "${pkgdir}/usr/bin"
    chmod -R 644 "${pkgdir}/usr/share"
    chmod 755 "${pkgdir}/usr/share"
}
