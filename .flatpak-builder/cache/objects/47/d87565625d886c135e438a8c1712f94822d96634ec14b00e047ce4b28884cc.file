          "type" : "shell"
        },
        {
          "dest" : "cargo/vendor/tur-rs",
          "contents" : "[package]\nname = \"tur-rs\"\nversion = \"0.9.2\"\nedition = \"2024\"\nauthors = [\"Syed Ali\"]\ndescription = \"A relentless, high-concurrency download manager built for speed and efficiency. Tur uses dynamic work-stealing and aligned storage to saturate your bandwidth while maintaining a minuscule memory footprint. Inspired by the legends, built for the modern Rust ecosystem.\"\nlicense = \"GPL-3.0-only\"\nreadme = \"README.md\"\nrepository = \"https://github.com/greykaizen/tur-rs\"\nhomepage = \"https://github.com/greykaizen/tur-rs\"\ncategories = [\"command-line-utilities\", \"network-programming\"]\nkeywords = [\"download\", \"manager\", \"fast\", \"concurrency\", \"rust\"]\n\n[[bin]]\nname = \"tur\"\npath = \"src/main.rs\"\n\n[features]\ndefault = [\"tui\"]\nlinux-io-uring-experimental = []\ntui = [\"ratatui\", \"crossterm\", \"indicatif\"]\nhttp3 = [\"quinn\", \"h3\", \"h3-quinn\", \"rustls\", \"webpki-roots\"]\n\n[dependencies]\nanyhow = \"1.0.102\"\nbincode = \"1.3.3\"\nbytes = \"1.11.1\"\nchrono = \"0.4.44\"\nfutures-util = \"0.3.32\"\nhttp = \"1.3.1\"\nhttp-body-util = \"0.1.3\"\ntower-service = \"0.3.3\"\nurl = \"2.5.7\"\n\n[dependencies.clap]\nversion = \"4.6.1\"\nfeatures = [\"derive\"]\n\n[dependencies.crossterm]\nversion = \"0.29.0\"\noptional = true\n\n[dependencies.hyper]\nversion = \"1.9.0\"\nfeatures = [\"client\", \"http1\", \"http2\"]\n\n[dependencies.hyper-rustls]\nversion = \"0.27.9\"\nfeatures = [\"http1\", \"http2\", \"native-tokio\", \"tls12\", \"webpki-roots\"]\n\n[dependencies.hyper-util]\nversion = \"0.1.20\"\nfeatures = [\"client\", \"client-legacy\", \"http1\", \"http2\", \"tokio\"]\n\n[dependencies.indicatif]\nversion = \"0.18.4\"\noptional = true\n\n[dependencies.ratatui]\nversion = \"0.30.0\"\noptional = true\n\n[dependencies.rustix]\nversion = \"1.1.4\"\nfeatures = [\"fs\", \"pipe\"]\n\n[dependencies.serde]\nversion = \"1.0.228\"\nfeatures = [\"derive\"]\n\n[dependencies.socket2]\nversion = \"0.6.3\"\nfeatures = [\"all\"]\n\n[dependencies.sysinfo]\nversion = \"0.30\"\ndefault-features = false\n\n[dependencies.tokio]\nversion = \"1.52.2\"\nfeatures = [\"fs\", \"full\", \"io-util\", \"rt-multi-thread\"]\n\n[dependencies.uuid]\nversion = \"1.23.1\"\nfeatures = [\"v4\", \"serde\"]\n\n[dependencies.quinn]\nversion = \"0.11\"\noptional = true\nfeatures = [\"runtime-tokio\", \"rustls-ring\"]\n\n[dependencies.h3]\nversion = \"0.0\"\noptional = true\n\n[dependencies.h3-quinn]\nversion = \"0.0\"\noptional = true\n\n[dependencies.rustls]\nversion = \"0.23\"\noptional = true\nfeatures = [\"ring\"]\n\n[dependencies.webpki-roots]\nversion = \"0.26\"\noptional = true\n\n[target.\"cfg(target_os = \\\"windows\\\")\".dependencies.windows-sys]\nversion = \"0.61.2\"\nfeatures = [\"Win32_Storage_FileSystem\", \"Win32_System_IO\", \"Win32_Networking_WinSock\"]\n\n[target.\"cfg(target_os = \\\"macos\\\")\".dependencies]\nlibc = \"0.2\"\n\n[target.\"cfg(target_os = \\\"linux\\\")\".dependencies]\ntokio-uring = \"0.5\"\n",
          "dest-filename" : "Cargo.toml",
          "type" : "inline"
        },
