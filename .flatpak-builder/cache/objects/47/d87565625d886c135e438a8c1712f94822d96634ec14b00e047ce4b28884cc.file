        {
          "dest" : "cargo",
          "contents" : "[source.vendored-sources]\ndirectory = \"cargo/vendor\"\n\n[source.crates-io]\nreplace-with = \"vendored-sources\"\n\n[source.\"https://github.com/greykaizen/tur-rs\"]\ngit = \"https://github.com/greykaizen/tur-rs\"\nreplace-with = \"vendored-sources\"\n",
          "dest-filename" : "config",
          "type" : "inline"
        },
        {
          "path" : "yarn.lock",
          "type" : "file"
        }
      ],
      "build-commands" : [
        "sed -i '/\"packageManager\":/d' package.json",
        "printf 'yarn-offline-mirror \"./flatpak-node/yarn-mirror\"\\nyarn-offline-mirror-pruning false\\n' > .yarnrc",
        "yarn install --offline --frozen-lockfile --non-interactive",
        "sed -i 's/\"bun run/\"yarn run/g' src-tauri/tauri.conf.json",
        "sed -i 's/TrayIconBuilder::with_id(\"main\")/TrayIconBuilder::with_id(\"com.kaizen.tur\")/g' src-tauri/src/lib.rs",
        "sed -i 's/tray_by_id(\"main\")/tray_by_id(\"com.kaizen.tur\")/g' src-tauri/src/lib.rs",
        "node_modules/.bin/tauri build --no-bundle",
        "install -Dm755 src-tauri/target/release/tur-tauri /app/bin/tur",
        "install -Dm644 src-tauri/icons/128x128.png /app/share/icons/hicolor/128x128/apps/com.kaizen.tur.png",
        "install -Dm644 src-tauri/icons/32x32.png /app/share/icons/hicolor/32x32/apps/com.kaizen.tur.png",
        "install -Dm644 src-tauri/icons/icon.png /app/share/icons/hicolor/512x512/apps/com.kaizen.tur.png",
        "install -Dm644 packaging/flatpak/com.kaizen.tur.desktop /app/share/applications/com.kaizen.tur.desktop",
        "install -Dm644 packaging/flatpak/com.kaizen.tur.metainfo.xml /app/share/metainfo/com.kaizen.tur.metainfo.xml"
      ]
    }
  ],
  "sdk-extensions" : [
